# Model directory
model_dir = muscal2 
model_data_path = https://g-3a9041.a78b8.36fe.data.globus.org/ucvm/models

/** 
       tiledb: tildb_ctx
          -file
              config ..nx/ny/nz
**/
// lon, NA or a value
nx = 1301 
// lat, NA or a value
ny = 1251
// depth, NA or a value
nz = 210

depth = NA
// fixed step, NA or a value
depth_interval = NA

// irregular steps, NA or an array of floats
depth_list = NA
// irregular steps, NA or an array of floats
latitude_list = NA
